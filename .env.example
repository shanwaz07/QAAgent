# ─────────────────────────────────────────
# LLM PROVIDER (set ACTIVE_LLM_PROVIDER to one of: openrouter | groq | openai | google)
# ─────────────────────────────────────────
ACTIVE_LLM_PROVIDER=google
ACTIVE_LLM_MODEL=gemma-3-27b-it

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Groq — https://console.groq.com/keys
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Google Gemini (LLM via Gemini API — separate from embeddings key below)
# https://aistudio.google.com
GOOGLE_LLM_API_KEY=
GOOGLE_LLM_MODEL=gemini-2.0-flash

# ─────────────────────────────────────────
# EMBEDDINGS (Google Gemini — free tier 1M tokens/day)
# ─────────────────────────────────────────
GOOGLE_API_KEY=
GEMINI_EMBED_MODEL=models/gemini-embedding-001

# ─────────────────────────────────────────
# VECTOR DB (Qdrant local Docker — no key needed)
# Start: docker run -p 6333:6333 -v ./qdrant_storage:/qdrant/storage qdrant/qdrant
# ─────────────────────────────────────────
QDRANT_URL=http://localhost:6333

# ─────────────────────────────────────────
# JIRA API
# Generate token at: https://id.atlassian.com/manage-profile/security/api-tokens
# ─────────────────────────────────────────
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=CBOT
JIRA_DEFAULT_ASSIGNEE=

# ─────────────────────────────────────────
# RAG TUNING (UI Settings Panel slider overrides per-session)
# ─────────────────────────────────────────
RAG_TOP_K=30

# ─────────────────────────────────────────
# TARGET APP UNDER TEST
# Convert careersite AI agent (Leoforce) — no login required, public careersite
# ─────────────────────────────────────────
APP_URL=https://leolity-qa.goarya.com/demo-staffing/home
APP_USERNAME=
APP_PASSWORD=
